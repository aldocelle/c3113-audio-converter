# FastAPI
APP_NAME=C3113 Audio Converter
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Redis (or memory: for testing without Redis)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# File processing
MAX_FILE_SIZE_MB=500
TEMP_DIR=./temp
UPLOAD_DIR=./uploads

# FFmpeg
FFMPEG_PATH=ffmpeg
FFMPEG_TIMEOUT_SECONDS=300

# Logging
LOG_LEVEL=INFO
